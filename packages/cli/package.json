{
  "name": "@togetherlink/cli",
  "version": "0.3.0",
  "description": "CLI for routing Claude Code, OpenCode, Codex, and Pi Code through Together AI",
  "type": "module",
  "bin": {
    "togetherlink": "./dist/bin/togetherlink.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/bin/togetherlink.js', 0o755)\"",
    "dev": "pnpm build && sh -c 'node scripts/watch-bin-mode.mjs & tsc -p tsconfig.json --watch --preserveWatchOutput'",
    "watch": "pnpm dev",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm build",
    "test": "pnpm typecheck"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "@togetherlink/models": "workspace:*"
  },
  "license": "Apache-2.0"
}
