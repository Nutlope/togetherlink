{
  "name": "@togetherlink/tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node scripts/run-vitest.mjs",
    "test:live-smoke": "TOGETHERLINK_LIVE_SMOKE=1 node scripts/run-vitest.mjs src/LiveSmoke.test.ts",
    "test:live-codex-resume": "TOGETHERLINK_LIVE_CODEX_RESUME=1 VITEST_FILE_PARALLELISM=0 node scripts/run-vitest.mjs src/LiveCodexResume.test.ts",
    "test:live-models-check": "TOGETHERLINK_LIVE_MODELS_CHECK=1 VITEST_MAX_CONCURRENCY=${VITEST_MAX_CONCURRENCY:-6} node scripts/run-vitest.mjs src/livemodelscheck.test.ts",
    "test:codex": "node scripts/run-vitest.mjs src/Codex.test.ts",
    "test:claude": "node scripts/run-vitest.mjs src/Claude.test.ts",
    "test:opencode": "node scripts/run-vitest.mjs src/OpenCode.test.ts",
    "test:grok": "node scripts/run-vitest.mjs src/Grok.test.ts",
    "test:pi": "node scripts/run-vitest.mjs src/Pi.test.ts",
    "test:gauntlet:core": "vitest run --config vitest.config.ts src/CodexProxyApi.test.ts src/ClaudeApi.test.ts src/livemodelscheck.test.ts src/codex-app.test.ts src/harness-invocation.test.ts src/vision.test.ts src/daemon-state.test.ts src/daemon-app-registration.test.ts src/model-resolver.test.ts src/LiveSmoke.test.ts src/command.test.ts src/telemetry.test.ts src/codex-exec.test.ts",
    "test:gauntlet:claude": "vitest run --config vitest.config.ts src/Claude.test.ts",
    "test:gauntlet:codex": "vitest run --config vitest.config.ts src/Codex.test.ts",
    "test:gauntlet:live-models-check": "TOGETHERLINK_LIVE_MODELS_CHECK=1 VITEST_MAX_CONCURRENCY=${VITEST_MAX_CONCURRENCY:-6} vitest run --config vitest.config.ts src/livemodelscheck.test.ts",
    "test:gauntlet:opencode": "vitest run --config vitest.config.ts src/OpenCode.test.ts",
    "test:gauntlet:grok": "vitest run --config vitest.config.ts src/Grok.test.ts",
    "test:gauntlet:pi": "vitest run --config vitest.config.ts src/Pi.test.ts",
    "bench:proxy": "pnpm -F @togetherlink/cli build && pnpm exec vitest run --config vitest.bench.config.ts benchmarks/proxy-performance.bench.ts --reporter verbose",
    "capture:proxy-fixtures": "pnpm -F @togetherlink/cli build && node scripts/capture-proxy-fixtures.mjs"
  },
  "devDependencies": {
    "@togetherlink/cli": "workspace:*",
    "@togetherlink/models": "workspace:*",
    "@types/node": "^26.0.0",
    "vitest": "^4.0.15"
  }
}
