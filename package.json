{
  "name": "togetherlink",
  "private": true,
  "version": "0.4.1",
  "description": "Use Together AI models in Claude Code, OpenCode, Codex, and Pi Code",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:bundle": "bash scripts/build-bundle.sh",
    "build:site": "pnpm build:bundle && pnpm --filter @togetherlink/site build",
    "dev": "pnpm -F @togetherlink/cli dev",
    "dev:site": "pnpm --filter @togetherlink/site dev",
    "test": "pnpm -F @togetherlink/tests test",
    "watch": "pnpm dev",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
